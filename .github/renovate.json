{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "enabledManagers": ["custom.regex"],
  "baseBranches": ["develop", "release"],
  "labels": ["dependencies", "renovate"],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["^ci/deps-dev\\.toml$"],
      "matchStrings": [
        "(?m)^greentic-qa-lib\\s*=\\s*\"(?<currentValue>[^\"]+)\"\\s*$"
      ],
      "depNameTemplate": "greenticai/greentic-qa",
      "datasourceTemplate": "github-tags",
      "versioningTemplate": "semver",
      "extractVersionTemplate": "^v?(?<version>.*)$"
    },
    {
      "customType": "regex",
      "fileMatch": ["^Cargo\\.toml$"],
      "matchStrings": [
        "(?m)^qa-spec\\s*=\\s*\"(?<currentValue>[^\"]+)\"\\s*$",
        "(?m)^greentic-qa-lib\\s*=\\s*\"(?<currentValue>[^\"]+)\"\\s*$"
      ],
      "depNameTemplate": "greenticai/greentic-qa",
      "datasourceTemplate": "github-tags",
      "versioningTemplate": "semver",
      "extractVersionTemplate": "^v?(?<version>.*)$"
    }
  ],
  "packageRules": [
    {
      "matchBaseBranches": ["develop"],
      "matchFileNames": ["ci/deps-dev.toml"],
      "automerge": true,
      "automergeType": "pr",
      "allowedVersions": "/-dev\\./",
      "additionalBranchPrefix": "develop-"
    },
    {
      "matchBaseBranches": ["release"],
      "matchFileNames": ["Cargo.toml"],
      "ignoreUnstable": true,
      "additionalBranchPrefix": "release-"
    },
    {
      "matchBaseBranches": ["release"],
      "matchFileNames": ["ci/deps-dev.toml"],
      "enabled": false
    },
    {
      "matchBaseBranches": ["develop"],
      "matchFileNames": ["Cargo.toml"],
      "enabled": false
    }
  ]
}
